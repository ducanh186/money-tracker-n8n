# Cloudflare Tunnel Token - get from Cloudflare Zero Trust dashboard
CF_TUNNEL_TOKEN=your_cloudflare_tunnel_token

# n8n Encryption Key - generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=your_n8n_encryption_key

# Timezone
GENERIC_TIMEZONE=Asia/Bangkok

# Persistent SQLite path on EC2 host.
# Keep this outside Docker volumes so budget data survives rebuilds and deploys.
ALMONEY_DATA_DIR=/opt/almoney/data/api
